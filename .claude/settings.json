{
  "permissions": {
    "allow": [
      "Read(*)",
      "Bash(*)",
      "Bash(git check-ignore *)",
      "Bash(npx nx *)",
      "Bash(uv run *)",
      "Bash(python -c ' *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/block_protected_paths.py"
          }
        ]
      }
    ]
  }
}
